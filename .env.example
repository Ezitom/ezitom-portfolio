# EmailJS Configuration
# Get these values from your EmailJS dashboard at https://dashboard.emailjs.com/

# Email Services -> Your Service -> Service ID  (looks like: service_xxxxxxx)
VITE_EMAILJS_SERVICE_ID=

# Email Templates -> Contact Notification template -> Template ID  (looks like: template_xxxxxxx)
VITE_EMAILJS_TEMPLATE_ID=

# Account -> API Keys -> Public Key  (looks like: xxxxxxxxxxxxxxxx)
VITE_EMAILJS_PUBLIC_KEY=

# Email Templates -> Password Reset template -> Template ID  (looks like: template_xxxxxxx)
VITE_EMAILJS_RESET_TEMPLATE_ID=
